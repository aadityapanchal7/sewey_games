    "body": "for now, I found a way around it(visibility is coming back from WASM, JS code just not adding it to result object...):\nI took tasks-vision.js(https://cdn.skypack.dev/@mediapipe/tasks-vision@0.10.0) to my local server and edited it to add visibility to the results\n```\nfunction convertToLandmarks(e) {\n  var t, r, o;\n  const i = [];\n  for (const a of e.getLandmarkList())\n    i.push({x: (t = a.getX()) !== null && t !== void 0 ? t : 0, y: (r = a.getY()) !== null && r !== void 0 ? r : 0, z: (o = a.getZ()) !== null && o !== void 0 ? o : 0\n    ,visibility: (t = a.getVisibility()) !== null && t !== void 0 ? t : 0});\n  return i;\n}\nfunction convertToWorldLandmarks(e) {\n  var t, r, o;\n  const i = [];\n  for (const a of e.getLandmarkList())\n    i.push({x: (t = a.getX()) !== null && t !== void 0 ? t : 0, y: (r = a.getY()) !== null && r !== void 0 ? r : 0, z: (o = a.getZ()) !== null && o !== void 0 ? o : 0\n    ,visibility: (t = a.getVisibility()) !== null && t !== void 0 ? t : 0});\n  return i;\n}\n```",
